# RetailCRM (demo) — см. docs/RETAILCRM_UPLOAD.md
RETAILCRM_API_URL=
RETAILCRM_API_KEY=
# Символьный код магазина (часто обязателен): Администрирование → Магазины → «Код»
RETAILCRM_SITE=
# Если API ругается на тип/способ/статус — подставьте коды из своего демо:
# RETAILCRM_ORDER_TYPE=
# RETAILCRM_ORDER_METHOD=
# RETAILCRM_ORDER_STATUS=
# RETAILCRM_COUNTRY_ISO=KZ
# RETAILCRM_INCLUDE_CUSTOM_FIELDS=1

# Supabase — Project Settings → API
# URL проекта (поле Project URL)
NEXT_PUBLIC_SUPABASE_URL=
# Публичный ключ: в панели «anon» / public ИЛИ Publishable (sb_publishable_…) — целиком, с префиксом
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Секретный ключ: «service_role» ИЛИ Secret (sb_secret_…) — целиком; только сервер / скрипты
SUPABASE_SERVICE_ROLE_KEY=

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# Порог суммы для уведомления (строго больше этого числа)
# TELEGRAM_ALERT_THRESHOLD_KZT=50000
# TELEGRAM_MODE=live

# Vercel Cron: GET /api/cron/sync проверяет Bearer
# CRON_SECRET=

# Очистка моков (npm run cleanup:*) — префикс external_id / externalId (по умолчанию gbc-mock-)
# CLEANUP_MOCK_PREFIX=gbc-mock-

# Полная очистка orders + order_events (Supabase) или всех заказов сайта (RetailCRM): только для пустого демо
# CLEANUP_ALL_CONFIRM=yes
# Пауза между DELETE в RetailCRM (cleanup:retailcrm:all), мс
# RETAILCRM_DELETE_DELAY_MS=120

# Синк: только заказы с externalId, начинающимся на префикс (например gbc-mock-)
# SYNC_ONLY_MOCK_PREFIX=gbc-mock-
# Перед upsert полностью очистить order_events + orders в Supabase (yes / 1 / true)
# SYNC_FULL_REPLACE=yes
